@using DFD.Application.ViewModels
@model DashboardStatsVM

@{
    ViewData["Title"] = "لوحة التحكم";
}

@section Breadcrumb {
    <span><i class="fas fa-chart-pie"></i> لوحة التحكم</span>
}

<!-- Stats Cards -->
<div class="stats-grid">
    <div class="stat-card primary">
        <div class="stat-icon"><i class="fas fa-folder"></i></div>
        <div class="stat-info">
            <h3>@Model.TotalFolders</h3>
            <p>المجلدات</p>
        </div>
    </div>
    <div class="stat-card success">
        <div class="stat-icon"><i class="fas fa-file-shield"></i></div>
        <div class="stat-info">
            <h3>@Model.FilesStats.TotalFiles</h3>
            <p>الملفات الفريدة</p>
        </div>
    </div>
    <div class="stat-card danger">
        <div class="stat-icon"><i class="fas fa-ban"></i></div>
        <div class="stat-info">
            <h3>@Model.UploadsStats.RejectedAttempts</h3>
            <p>محاولات مرفوضة</p>
        </div>
    </div>
    <div class="stat-card warning">
        <div class="stat-icon"><i class="fas fa-database"></i></div>
        <div class="stat-info">
            <h3>@Model.FilesStats.FormattedTotalStorage</h3>
            <p>المساحة المستخدمة</p>
        </div>
    </div>
</div>

<!-- Storage & File Types -->
<div style="display: grid; grid-template-columns: 1fr 1fr; gap: 24px; margin-bottom: 24px;">
    <!-- Storage Progress -->
    <div class="card">
        <div class="card-header">
            <h2 class="card-title"><i class="fas fa-hard-drive"></i> مساحة التخزين</h2>
        </div>
        <div style="padding: 20px 0;">
            <div style="display: flex; justify-content: space-between; margin-bottom: 12px; font-size: 0.9rem;">
                <span style="color: var(--gray-600);">مستخدم: <strong>@Model.FilesStats.FormattedTotalStorage</strong></span>
                <span style="color: var(--gray-600);">متاح: <strong>@Model.FilesStats.FormattedAvailableStorage</strong></span>
            </div>
            
            <div class="storage-bar"
                 style="height: 12px; background: var(--gray-200); border-radius: 6px; overflow: hidden;">
                <div class="storage-fill" style="width: @(Math.Min(Model.FilesStats.StoragePercentage, 100))%; height: 100%; 
                            background: @(Model.FilesStats.StorageColor);" );border-radius: 6px; transition: width 0.5s ease;">
                </div>
            </div>
            
            <div style="display: flex; justify-content: space-between; margin-top: 8px; font-size: 0.85rem;">
                <span style="color: var(--gray-500);">@Model.FilesStats.StoragePercentage.ToString("F3")% مستخدم</span>
                @if (Model.FilesStats.StoragePercentage > 90)
                {
                    <span style="color: var(--danger); font-weight: 600;"><i class="fas fa-triangle-exclamation"></i> مساحة
                        شبه ممتلئة!</span>
                    }
                </div>
            </div>
        </div>

        <!-- File Types Distribution -->
        <div class="card">
            <div class="card-header">
                <h2 class="card-title"><i class="fas fa-chart-pie"></i> توزيع الملفات</h2>
            </div>
            <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px; padding: 10px 0;">
                <div
                    style="text-align: center; padding: 16px; background: rgba(59, 130, 246, 0.08); border-radius: var(--radius);">
                    <i class="fas fa-images" style="font-size: 1.5rem; color: var(--info); margin-bottom: 8px;"></i>
                    <h4 style="font-size: 1.3rem; font-weight: 700; color: var(--dark);">@Model.FilesStats.ImagesCount</h4>
                    <p style="font-size: 0.8rem; color: var(--gray-500);">صور</p>
                </div>
                <div
                    style="text-align: center; padding: 16px; background: rgba(239, 68, 68, 0.08); border-radius: var(--radius);">
                    <i class="fas fa-file-pdf" style="font-size: 1.5rem; color: var(--danger); margin-bottom: 8px;"></i>
                    <h4 style="font-size: 1.3rem; font-weight: 700; color: var(--dark);">@Model.FilesStats.PdfsCount</h4>
                    <p style="font-size: 0.8rem; color: var(--gray-500);">PDFs</p>
                </div>
                <div
                    style="text-align: center; padding: 16px; background: rgba(99, 102, 241, 0.08); border-radius: var(--radius);">
                    <i class="fas fa-file" style="font-size: 1.5rem; color: var(--primary); margin-bottom: 8px;"></i>
                    <h4 style="font-size: 1.3rem; font-weight: 700; color: var(--dark);">@Model.FilesStats.OtherFilesCount</h4>
                    <p style="font-size: 0.8rem; color: var(--gray-500);">أخرى</p>
                </div>
            </div>
        </div>
    </div>

    <!-- Recent Files & Attempts -->
    <div style="display: grid; grid-template-columns: 2fr 1fr; gap: 24px;">
        <!-- Recent Files -->
        <div class="card">
            <div class="card-header">
                <h2 class="card-title"><i class="fas fa-clock-rotate-left"></i> آخر الملفات المرفوعة</h2>
                <a asp-controller="Files" asp-action="Index" class="btn btn-sm btn-primary">عرض الكل</a>
            </div>
        
                    @if (!Model.FilesStats.RecentFiles.Any())
            {
                <div class="empty-state" style="padding: 40px;">
                    <i class="fas fa-file-circle-xmark"></i>
                    <h3>لا يوجد ملفات حديثة</h3>
                    <p>لم يتم رفع ملفات في آخر 5 أيام</p>
                </div>
            }
            else
            {
                <table class="data-table">
                    <thead>
                        <tr>
                            <th>الملف</th>
                            <th>المجلد</th>
                            <th>التاريخ</th>
                        </tr>
                    </thead>
                    <tbody>
                                @foreach (var file in Model.FilesStats.RecentFiles)
                        {
                            <tr>
                                <td>
                                    <div class="file-row">
                                        <i class="fas @file.FileIcon" style="color: var(--primary); font-size: 1.2rem;"></i>
                                        <span style="font-weight: 500;">@file.OriginalFileName</span>
                                    </div>
                                </td>
                                <td>
                                    <span class="badge badge-success">
                                        <i class="fas fa-folder"></i> @file.FolderName
                                    </span>
                                </td>
                                <td style="color: var(--gray-500); font-size: 0.9rem;">
                                    @file.UploadedAt.ToString("yyyy-MM-dd")
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        </div>

        <!-- Recent Attempts -->
        <div class="card">
            <div class="card-header">
                <h2 class="card-title"><i class="fas fa-shield-halved"></i> آخر المحاولات</h2>
                <a asp-controller="UploadAttempts" asp-action="Index" class="btn btn-sm btn-secondary">السجل</a>
            </div>
        
            @if (!Model.UploadsStats.RecentAttempts.Any())
            {
                <div class="empty-state" style="padding: 40px;">
                    <i class="fas fa-shield-halved"></i>
                    <h3>لا يوجد محاولات</h3>
                    <p>لم يتم تسجيل محاولات في آخر 5 أيام</p>
                </div>
            }
            else
            {
                <div style="display: flex; flex-direction: column; gap: 12px;">
                    @foreach (var attempt in Model.UploadsStats.RecentAttempts)
                    {
                        <div
                            style="display: flex; align-items: center; gap: 12px; padding: 12px; 
                            background: @(attempt.IsRejected ? "rgba(239, 68, 68, 0.05)" : "rgba(16, 185, 129, 0.05)"); 
                            border-radius: var(--radius); border-right: 3px solid @(attempt.IsRejected ? "var(--danger)" : "var(--success)");">
                        
                            <div style="width: 36px; height: 36px; border-radius: 50%; 
                                background: @(attempt.IsRejected ? "rgba(239, 68, 68, 0.1)" : "rgba(16, 185, 129, 0.1)");
                                display: flex; align-items: center; justify-content: center;">
                                <i class="fas @(attempt.IsRejected ? "fa-ban" : "fa-check")"
                                   style="color: @(attempt.IsRejected ? "var(--danger)" : "var(--success)"); font-size: 0.9rem;"></i>
                            </div>
                        
                            <div style="flex: 1; min-width: 0;">
                                <p
                                    style="font-weight: 500; font-size: 0.9rem; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">
                                    @attempt.FileName
                                </p>
                                <p style="font-size: 0.75rem; color: var(--gray-400);">
                                    @attempt.AttemptedAt.ToString("yyyy-MM-dd")
                                </p>
                            </div>
                        
                            <span class="badge @(attempt.IsRejected ? "badge-danger" : "badge-success")" style="font-size: 0.7rem;">
                                @(attempt.IsRejected ? "مرفوض" : "ناجح")
                            </span>
                        </div>
                    }
                </div>
            }
        </div>
    </div>