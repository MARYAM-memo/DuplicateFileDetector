@model FolderEditVM

@{
    ViewData["Title"] = "تعديل مجلد";
}

@section Breadcrumb {
    <a asp-action="Index"><i class="fas fa-folder-tree"></i> المجلدات</a>
    <span class="mx-2">/</span>
    <span>تعديل: @Model.Name</span>
}

<div class="card" style="max-width: 600px;">
    <div class="card-header">
        <h2 class="card-title"><i class="fas fa-folder-open"></i> تعديل المجلد</h2>
    </div>

    <form asp-action="Edit" method="post">
        <input type="hidden" asp-for="Id" />
        <input type="hidden" asp-for="UpdatedAt" />

        <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

        <div class="form-group">
            <label asp-for="Name">اسم المجلد</label>
            <input asp-for="Name" class="form-select" style="text-align: right;" />
            <span asp-validation-for="Name" class="text-danger"
                  style="color: var(--danger); font-size: 0.85rem;"></span>
        </div>

        <div class="form-group">
            <label asp-for="Description">الوصف</label>
            <textarea asp-for="Description" class="form-select" rows="3"
                      style="text-align: right; resize: vertical;"></textarea>
        </div>

        <div class="modal-actions">
            <a asp-action="Index" class="btn btn-secondary">إلغاء</a>
            <button type="submit" class="btn btn-primary"><i class="fas fa-save"></i> حفظ التغييرات</button>
        </div>
    </form>
</div>